.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #c0392b;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 80rpx;
}

.error-box {
  background: #fde;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  width: 100%;
}

.login-btn {
  width: 100%;
  background: #c0392b;
  border-radius: 12rpx;
  font-size: 34rpx;
}

.privacy {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}
