.container {
  padding: 30rpx;
  background: #f7f7f7;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 80rpx 40rpx;
}

/* Official enrollment card (shown after admin assigns class) */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin: 30rpx 0 8rpx;
}

.enrollment-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.student-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.status-enrolled { background: #d4edda; color: #155724; }
.status-waitlisted { background: #fff3cd; color: #856404; }

.class-name {
  font-size: 30rpx;
  color: #555;
  display: block;
  margin-bottom: 8rpx;
}

.waitlist-info {
  font-size: 26rpx;
  color: #856404;
  background: #fff3cd;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
}

/* Submission confirmation card */
.result-card {
  background: white;
  border-radius: 16rpx;
  padding: 50rpx 40rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  text-align: center;
}

.check-icon {
  width: 120rpx;
  height: 120rpx;
  background: #27ae60;
  border-radius: 50%;
  color: white;
  font-size: 60rpx;
  line-height: 120rpx;
  margin: 0 auto 30rpx;
}

.result-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #27ae60;
  display: block;
  margin-bottom: 40rpx;
}

.level-block {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 36rpx;
  text-align: left;
}

.level-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.level-row:last-child {
  margin-bottom: 0;
}

.level-label {
  font-size: 28rpx;
  color: #666;
  width: 300rpx;
  flex-shrink: 0;
}

.level-badge {
  background: #c0392b;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.level-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #c0392b;
}

.result-hint {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  display: block;
}
